{
  "entities": {
    "Siswa": {
      "title": "Siswa",
      "description": "Data siswa perpustakaan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" },
        "kelas": { "type": "string" }
      },
      "required": ["id", "nama", "kelas"]
    },
    "Guru": {
      "title": "Guru",
      "description": "Data guru perpustakaan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" }
      },
      "required": ["id", "nama"]
    },
    "Buku": {
      "title": "Buku",
      "description": "Data buku perpustakaan",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "no": { "type": "number" },
        "judul": { "type": "string" },
        "jenis": { "type": "string" },
        "edisi": { "type": "string" },
        "isbn_issn": { "type": "string" },
        "penerbit": { "type": "string" },
        "tahun": { "type": "string" },
        "kolasi": { "type": "string" },
        "judul_seri": { "type": "string" },
        "nomor_panggil": { "type": "string" },
        "bahasa_buku": { "type": "string" },
        "kota_terbit": { "type": "string" },
        "nomor_kelas": { "type": "string" },
        "catatan": { "type": "string" },
        "penanggung_jawab": { "type": "string" },
        "pengarang": { "type": "string" },
        "subjek": { "type": "string" },
        "kode_eksemplar": { "type": "string" }
      },
      "required": ["id", "judul", "kode_eksemplar"]
    },
    "Transaksi": {
      "title": "Transaksi",
      "description": "Data transaksi peminjaman dan pengembalian",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tglPinjam": { "type": "string" },
        "jam": { "type": "string" },
        "siswa": { "type": "string" },
        "kelas": { "type": "string" },
        "buku": { "type": "string" },
        "subjek": { "type": "string" },
        "kode_eksemplar": { "type": "string" },
        "jenis": { "type": "string" },
        "pengarang": { "type": "string" },
        "penerbit": { "type": "string" },
        "tglKembali": { "type": "string" },
        "status": { "type": "string" },
        "tglDikembalikan": { "type": "string" }
      },
      "required": ["id", "siswa", "buku", "status"]
    },
    "Kunjungan": {
      "title": "Kunjungan",
      "description": "Data kunjungan kelas",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tgl": { "type": "string" },
        "kelas": { "type": "string" },
        "guru": { "type": "string" },
        "mapel": { "type": "string" },
        "jam": { "type": "string" }
      },
      "required": ["id", "tgl", "kelas"]
    },
    "KunjunganSiswa": {
      "title": "KunjunganSiswa",
      "description": "Data kunjungan siswa mandiri",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tgl": { "type": "string" },
        "jam": { "type": "string" },
        "kelas": { "type": "string" },
        "nama": { "type": "string" },
        "keperluan": { "type": "string" }
      },
      "required": ["id", "tgl", "nama"]
    },
    "Mapel": {
      "title": "Mapel",
      "description": "Data mata pelajaran",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nama": { "type": "string" }
      },
      "required": ["id", "nama"]
    },
    "Jam": {
      "title": "Jam",
      "description": "Data jam pelajaran",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" }
      },
      "required": ["id", "label"]
    }
  },
  "firestore": {
    "/siswa/{siswaId}": { "schema": { "$ref": "Siswa" }, "description": "Koleksi data siswa" },
    "/guru/{guruId}": { "schema": { "$ref": "Guru" }, "description": "Koleksi data guru" },
    "/buku/{bukuId}": { "schema": { "$ref": "Buku" }, "description": "Koleksi data buku" },
    "/transaksi/{transaksiId}": { "schema": { "$ref": "Transaksi" }, "description": "Koleksi data transaksi" },
    "/kunjungan/{kunjunganId}": { "schema": { "$ref": "Kunjungan" }, "description": "Koleksi data kunjungan kelas" },
    "/kunjunganSiswa/{kunjunganSiswaId}": { "schema": { "$ref": "KunjunganSiswa" }, "description": "Koleksi data kunjungan siswa" },
    "/mapel/{mapelId}": { "schema": { "$ref": "Mapel" }, "description": "Koleksi data mata pelajaran" },
    "/jam/{jamId}": { "schema": { "$ref": "Jam" }, "description": "Koleksi data jam pelajaran" }
  }
}
